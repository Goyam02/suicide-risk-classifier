    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))",
    "",
    "# 1. WHO: Suicide Rate by Age",
    "who_data = {",
    "    'Age Group': ['10-24', '25-34', '35-44', '45-54', '55-64', '65+'],",
    "    'Rate per 100k': [14.5, 13.8, 14.2, 15.1, 14.8, 16.2]",
    "}",
    "who_df = pd.DataFrame(who_data)",
    "colors = plt.cm.Blues(np.linspace(0.4, 0.9, len(who_df)))",
    "axes[0].bar(who_df['Age Group'], who_df['Rate per 100k'], color=colors, edgecolor='black')",
